EXPO_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
EXPO_PUBLIC_SUPABASE_ANON_KEY=YOUR_SUPABASE_ANON_KEY
# Optional: dev-only auto sign in on app launch.
# EXPO_PUBLIC_ENABLE_AUTO_SIGNIN=1
# EXPO_PUBLIC_AUTO_SIGNIN_EMAIL=you@example.com
# EXPO_PUBLIC_AUTO_SIGNIN_PASSWORD=change-me-please
SUPABASE_SEED_EMAIL=you@example.com
SUPABASE_SEED_PASSWORD=change-me-please
# Optional privileged path (bypasses confirmation/RLS for seeding script only):
# SUPABASE_SERVICE_ROLE_KEY=sb_secret_xxx
# Optional direct target:
# SUPABASE_SEED_USER_ID=uuid
# Optional: set true/1 to auto-create account if it does not exist.
# SUPABASE_AUTO_SIGNUP=1
